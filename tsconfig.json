{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "types": ["bun"],
    "paths": {
      "@oneshot-gtm/core": ["./packages/core/src/index.ts"],
      "@oneshot-gtm/intel": ["./packages/intel/src/index.ts"],
      "@oneshot-gtm/plays": ["./packages/plays/src/index.ts"],
      "@oneshot-gtm/doctor": ["./packages/doctor/src/index.ts"],
      "@oneshot-gtm/ledger": ["./packages/ledger/src/index.ts"],
      "@oneshot-gtm/shared-types": ["./packages/shared-types/src/index.ts"]
    }
  },
  "include": [
    "apps/cli/src/**/*.ts",
    "apps/server/src/**/*.ts",
    "packages/*/src/**/*.ts",
    "packages/*/__tests__/**/*.ts"
  ],
  "exclude": ["node_modules", "dist", "apps/web"]
}
