# oneshot-gtm — example env file
#
# The CLI prefers ~/.oneshot-gtm/.env (chmod 600) — set those keys by running
# `oneshot-gtm init` or `oneshot-gtm config keys`. This file is just a reference
# of what env vars the runtime reads if they're set in your shell instead.
#
# DO NOT commit a real .env file. The .gitignore catches .env and .env.*
# (the !.env.example exception keeps THIS file trackable).

# ── LLM provider (pick the one matching your `oneshot-gtm config llm` choice) ─
OPENROUTER_API_KEY=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# ── OneShot wallet (pick CDP server wallet OR raw private key) ───────────────
# Option A — Coinbase Developer Platform server wallet (recommended)
CDP_API_KEY_ID=
CDP_API_KEY_SECRET=
CDP_WALLET_SECRET=

# Option B — raw private key (skip the CDP_* vars if you use this)
# AGENT_PRIVATE_KEY=

# ── Optional ─────────────────────────────────────────────────────────────────
# PORT=3030                       # dashboard port (default 3030)
# ONESHOT_GTM_NO_BROWSER=1        # don't auto-open the browser when `ui` boots
# ONESHOT_GTM_TELEMETRY=0         # hard-kill telemetry at the call site
