# ==============================================================================
# oneshot-gtm .gitignore
#
# Note: bun.lock is NOT ignored — it's the lockfile and SHOULD be committed
# for reproducible installs. Bun 1.3+ uses text-based bun.lock; the older
# binary format (bun.lockb) is excluded below in case any tooling produces it.
# ==============================================================================

# ── Dependencies ──────────────────────────────────────────────────────────────
node_modules/
.pnp/
.pnp.js
.yarn/

# ── Build output (per-app + per-package dist/) ────────────────────────────────
dist/
dist-electron/
build/
out/
.tsbuildinfo
*.tsbuildinfo
.next/
.nuxt/
.svelte-kit/

# ── Bun ───────────────────────────────────────────────────────────────────────
# bun.lock is committed (text). bun.lockb (binary, legacy) is ignored.
bun.lockb
.bun/

# ── Turborepo + TanStack + Vite caches ────────────────────────────────────────
.turbo/
.tanstack/
.vite/

# ── Auto-generated by TanStack Router file-based routing ──────────────────────
**/routeTree.gen.ts
**/route-tree.gen.ts

# ── Test + coverage ───────────────────────────────────────────────────────────
coverage/
.nyc_output/
*.lcov

# ── Local secrets (never commit) ──────────────────────────────────────────────
.env
.env.*
!.env.example

# ── Local ledger + per-user state ─────────────────────────────────────────────
# Users' SQLite ledgers should never be committed. The CLI writes them to
# ~/.oneshot-gtm/ledger.sqlite by default; this rule catches stragglers.
.oneshot-gtm/
*.sqlite
*.sqlite-journal
*.sqlite-wal
*.sqlite-shm
*.db
*.db-journal

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ── Editor / IDE ──────────────────────────────────────────────────────────────
.vscode/
!.vscode/extensions.json
!.vscode/settings.shared.json
.idea/
.fleet/
.zed/
*.swp
*.swo
*~
.cursor/

# ── OS junk ───────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# ── Runtime / temp ────────────────────────────────────────────────────────────
.cache/
tmp/
temp/
.tmp/

# ── Maintainer ops tooling (not for the public repo) ──────────────────────────
# First-party backend infra (the telemetry ingest service + its deploy
# scripts). It describes our hosting/storage topology, so it's maintainer-local
# and kept out of the public tree. See ops/telemetry-ingest/README.md locally.
/ops/

# ── User-supplied target / cohort / transcript files (privacy) ────────────────
# Real prospect lists shouldn't end up in git. Keep the example files,
# ignore anything you write next to them.
examples/*.local.json
examples/*.private.json
*.cohort.txt
*.cohort.csv
.transcripts/
