{
  "name": "oneshot-gtm-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "Open-source GTM agent for technical founders. Pay-per-result, signed receipts.",
  "license": "MIT",
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "@types/bun": "latest",
      "typescript": "^6.0.3",
      "vitest": "^4.0.0"
    }
  },
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint --report-unused-disable-directives",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "cli": "bun run apps/cli/src/index.ts",
    "ui": "bun run apps/server/src/bin.ts",
    "release:server": "git tag v$(node -p \"require('./apps/server/package.json').version\") && git push --follow-tags"
  },
  "dependencies": {
    "@fontsource-variable/host-grotesk": "^5.2.8"
  },
  "devDependencies": {
    "@types/bun": "catalog:",
    "oxfmt": "^0.46.0",
    "oxlint": "^1.55.0",
    "turbo": "^2.3.3",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "bun": ">=1.3.0"
  },
  "packageManager": "bun@1.3.13"
}
